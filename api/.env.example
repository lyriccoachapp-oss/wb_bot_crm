APP_NAME="WorkBangers CRM API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.workbangers.com
APP_TIMEZONE=America/Halifax

DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=workbangers_crm
DB_USERNAME=wb_crm
DB_PASSWORD=

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@workbangers.com
MAIL_FROM_NAME="WorkBangers CRM"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OCR_ENDPOINT=http://host.docker.internal:8868/ocr
OCR_TIMEOUT=180

TELEGRAM_BOT_TOKEN=

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
