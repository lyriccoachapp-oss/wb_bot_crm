FROM paddlepaddle/paddle:2.6.1

# Библиотека для cv2 (GUI не нужен, но glib бывает нужен)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
 && rm -rf /var/lib/apt/lists/*

# Обновим pip и поставим по constraints (см. constraints.txt ниже)
WORKDIR /app
COPY constraints.txt /app/constraints.txt

# Сначала понижаем/фиксируем numpy, затем ставим headless OpenCV, затем paddleocr и flask.
RUN python -m pip install --upgrade --no-cache-dir pip \
 && pip install --no-cache-dir -c constraints.txt numpy \
 && pip install --no-cache-dir -c constraints.txt opencv-python-headless \
 && pip install --no-cache-dir -c constraints.txt paddleocr flask

# Копируем сервер
COPY server.py /app/server.py

EXPOSE 8868
CMD ["python", "server.py"]